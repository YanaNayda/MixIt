<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
<item android:state_focused="true">
    <shape android:shape="rectangle">
        <solid android:color="#004D3FB5" /> <!-- Цвет фона при фокусе -->
        <stroke
            android:width="2dp"
            android:color="#FFFFFF" /> <!-- Цвет рамки при фокусе -->
        <corners android:radius="50dp"/>
        <padding
            android:left="70dp"
            android:right="20dp"/>
    </shape>
</item>
<item>
    <shape android:shape="rectangle">
        <solid android:color="#00000000" /> <!-- Цвет обычного фона -->
        <stroke
            android:width="2dp"
            android:color="#FFFFFF" /> <!-- Цвет обычной рамки -->
        <corners android:radius="50dp"/>
        <padding
            android:left="70dp"
            android:right="20dp"/>
    </shape>
</item>
</selector>