    <style name="NoRippleBottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemRippleColor">@null</item>
        <item name="itemBackground">@android:color/transparent</item>
    </style>


    <style name="Theme.MixIt" parent="Base.Theme.MixIt" />
</resources>